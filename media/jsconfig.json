{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "checkJs": true,
    "noEmit": true,
    "allowJs": true,
    "strict": false,
    "skipLibCheck": true,
    "types": []
  },
  "include": ["globals.d.ts", "core/**/*.js", "render/**/*.js", "ui/**/*.js", "features/**/*.js", "chat/**/*.js", "panels/**/*.js", "app/**/*.js"],
  "exclude": ["node_modules"]
}
